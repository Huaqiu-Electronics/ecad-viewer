{
    "name": "kicad-sexpr-parser",
    "version": "1.4.1",
    "description": "KiCad sexpr file parser",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "keywords": [
        "kicad",
        "eda",
        "sexpr",
        "parser"
    ],
    "author": "Ethan Chien",
    "license": "MIT",
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "^20.11.30",
        "esbuild": "^0.25.0",
        "jest": "^29.7.0",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.4.9",
        "tsx": "^4.21.0",
        "typescript": "^5.2.2"
    },
    "scripts": {
        "build": "rimraf dist && esbuild src/index.ts --bundle --platform=node --format=cjs --outfile=dist/index.js && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs && tsc --emitDeclarationOnly",
        "watch": "tsc --watch",
        "lint": "tsc --noEmit -p tsconfig.test.json",
        "test": "jest"
    }
}
