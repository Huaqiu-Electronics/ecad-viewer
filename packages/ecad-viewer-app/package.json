{
    "name": "ecad-viewer-app",
    "version": "1.0.0",
    "description": "ECAD Viewer Application",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "dependencies": {
        "comlink": "^4.4.2",
        "immutable": "^5.0.0-beta.5",
        "jszip": "^3.10.1",
        "kicad-parser": "file:../kicad-parser"
    },
    "devDependencies": {
        "@esm-bundle/chai": "^4.3.4-fix.0",
        "@open-wc/semantic-dom-diff": "^0.20.1",
        "@types/command-line-args": "^5.2.3",
        "@types/mocha": "^10.0.4",
        "@types/three": "^0.160.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@web/dev-server-esbuild": "^1.0.0",
        "@web/test-runner": "^0.18.0",
        "command-line-args": "^5.2.1",
        "esbuild": "^0.27.2",
        "esbuild-plugin-copy": "^2.1.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^9.0.0",
        "eslint-plugin-mocha": "^10.2.0",
        "prettier": "^3.0.3",
        "svgstore": "^3.0.1",
        "typescript": "^5.2.2",
        "typescript-lit-html-plugin": "^0.9.0"
    },
    "scripts": {
        "test:watch": "web-test-runner --config ../../scripts/web-test-runner.config.mjs --watch",
        "test:coverage": "web-test-runner --config ../../scripts/web-test-runner.config.mjs --coverage",
        "test": "web-test-runner --config ../../scripts/web-test-runner.config.mjs",
        "lint:eslint": "eslint --config .eslintrc.cjs src/ --ext .js,.ts",
        "lint:types": "tsc -p tsconfig.json",
        "lint:prettier": "prettier . --check",
        "lint": "npm run lint:eslint && npm run lint:prettier",
        "format": "prettier . --write",
        "serve": "node ./scripts/serve.js",
        "build:no-check": "node ./scripts/build.js",
        "build:font": "node ./scripts/build-font.js",
        "build:sprites": "node ./scripts/build-sprites.js",
        "build": "node ./scripts/build.js",
        "build:3d": " node ./scripts/build-3d.js",
        "build:glyph": " node ./scripts/build-glyph.js",
        "build-all": "cd ../kicad-parser && npm install && npm run build && cd ../ecad-viewer-app && npm run build:no-check && npm run build:glyph && npm run build:3d",
        "clean": "rm -rf build && rm -rf static/ecad-viewer"
    }
}
